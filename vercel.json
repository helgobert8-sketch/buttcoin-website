{
  "rewrites": [
    { "source": "/for-ai", "destination": "/for-ai.html" },
    { "source": "/church", "destination": "/church.html" },
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://apis.google.com https://fonts.googleapis.com; object-src 'none';"
        }
      ]
    }
  ]
}
